   return TRUE;
 }
 
+gboolean
+gum_arm64_writer_put_movz_reg_imm (GumArm64Writer * self,
+                                   arm64_reg dst_reg,
+                                   guint16 imm,
+                                   guint8 shift)
+{
+  GumArm64RegInfo ri;
+  guint32 hw;
+
+  gum_arm64_writer_describe_reg (self, dst_reg, &ri);
+
+  if (ri.width != 64)
+    return FALSE;
+  if (shift != 0 && shift != 16 && shift != 32 && shift != 48)
+    return FALSE;
+
+  hw = shift / 16;
+
+  gum_arm64_writer_put_instruction (self,
+      ri.sf | 0x52800000 | (hw << 21) | ((guint32) imm << 5) | ri.index);
+
+  return TRUE;
+}
+
+gboolean
+gum_arm64_writer_put_movk_reg_imm (GumArm64Writer * self,
+                                   arm64_reg dst_reg,
+                                   guint16 imm,
+                                   guint8 shift)
+{
+  GumArm64RegInfo ri;
+  guint32 hw;
+
+  gum_arm64_writer_describe_reg (self, dst_reg, &ri);
+
+  if (ri.width != 64)
+    return FALSE;
+  if (shift != 0 && shift != 16 && shift != 32 && shift != 48)
+    return FALSE;
+
+  hw = shift / 16;
+
+  gum_arm64_writer_put_instruction (self,
+      ri.sf | 0x72800000 | (hw << 21) | ((guint32) imm << 5) | ri.index);
+
+  return TRUE;
+}
+
